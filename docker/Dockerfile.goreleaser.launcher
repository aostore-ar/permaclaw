FROM alpine:3.21

ARG TARGETPLATFORM

RUN apk add --no-cache ca-certificates tzdata

COPY $TARGETPLATFORM/permaclaw /usr/local/bin/permaclaw
COPY $TARGETPLATFORM/permaclaw-launcher /usr/local/bin/permaclaw-launcher
COPY $TARGETPLATFORM/permaclaw-launcher-tui /usr/local/bin/permaclaw-launcher-tui

ENTRYPOINT ["permaclaw-launcher"]
CMD ["-public", "-no-browser"]